{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MSR Downloader",
  "version": "0.5.0",
  "identifier": "com.sylvan-cheng.msr-downloader",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": {
        "default-src": "'self' ipc: http://ipc.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost https://monster-siren.hypergryph.com https://web.hycdn.cn",
        "img-src": "'self' asset: http://asset.localhost https://web.hycdn.cn data: blob:",
        "style-src": "'self' 'unsafe-inline'"
      }
    },
    "windows": [
      {
        "title": "MSR Downloader",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620
      }
    ]
  }
}
